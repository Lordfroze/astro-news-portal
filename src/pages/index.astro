---
import Card from "../components/Card.astro"; // import Card component
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content"; // Mengimport fungsi getCollection dari astro:content
const blogPosts = await getCollection("blog"); // Mendapatkan koleksi blog dari folder blog
---

<MainLayout title="Homepage">
  <h1>Homepage</h1>
  <!-- <h2>Slider Posts</h2>

  <ul>
    {
      blogPosts
        .filter((post) => post.data.isPinned)
        .map((post) => (
          <li>
            <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          </li>
        ))
    }
  </ul> -->

  <!-- Articles -->
  <main class="container mt-content">
    <div class="row row-cols-1 row-cols-md-3 g-4">
      {
        blogPosts.map((post) => (
          <div class="col">
            <Card post={post} />
          </div>
        ))
      }
    </div>
  </main>
</MainLayout>
